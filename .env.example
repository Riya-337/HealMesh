# HealMesh Environment Variables
# Copy this file to .env (NEVER commit .env to git)

# ============================================================
# LLM Provider (Phase 0/1: Google Gemini free tier)
# Get your free key at: https://aistudio.google.com/app/apikey
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# Slack Integration
# ============================================================
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_CHANNEL_ID=C0XXXXXXXXX

# ============================================================
# Postgres Database
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=healmesh
POSTGRES_USER=healmesh
POSTGRES_PASSWORD=your_postgres_password

# ============================================================
# healmesh-core service
# ============================================================
CORE_HOST=0.0.0.0
CORE_PORT=8000

# ============================================================
# healmesh-k8s watcher
# ============================================================
WATCH_NAMESPACES=default
CORE_URL=http://localhost:8000
KUBECONFIG_PATH=

# ============================================================
# Rate limiting & cost control
# ============================================================
LLM_MAX_CALLS_PER_MINUTE=30
LLM_MAX_LOG_LINES=50
LLM_MAX_LINE_CHARS=500

# ============================================================
# Phase 2+ (leave empty in Phase 1)
# ============================================================
# VAULT_ADDR=
# VAULT_TOKEN=
